{
  "images_dir": "data/raw/Images",
  "processed_dir": "data/processed",

  "encoder_dim": 2048,
  "embed_size": 256,
  "hidden_size": 512,
  "attention_dim": 256,
  "dropout": 0.5,
  "rnn_type": "lstm",

  "alpha_c": 1.0,

  "batch_size": 32,
  "num_workers": 4,
  "num_epochs": 25,
  "decoder_lr": 4e-4,
  "encoder_lr": 1e-5,
  "weight_decay": 0.0,
  "grad_clip": 5.0,
  "scheduler_patience": 3,
  "scheduler_factor": 0.5,

  "fine_tune_start_epoch": 16,
  "fine_tune_blocks": 2,

  "seed": 42,
  "save_dir": "models",
  "run_name": "attention_lstm",
  "log_interval": 50,
  "val_bleu_subset": 200,
  "wandb_project": "flickr8k-captioning",
  "wandb_mode": "online"
}
